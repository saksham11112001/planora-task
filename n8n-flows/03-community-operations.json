    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "id": "nl-merge",
      "name": "NL: Merge Newsletter Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [480, 560]
    },
    {
      "parameters": {
        "jsCode": "const posts = $('NL: Fetch Week\\'s Top Posts').all().map(i => i.json);\nconst newMemberCount = parseInt($('NL: Fetch New Members This Week').item.json[0]?.count || '0');\nconst postsText = posts.map((p, i) =>\n  `${i+1}. \"${p.idea_title}\" — ${p.li_impressions || 0} impressions, ${p.li_reactions || 0} reactions`\n).join('\\n');\nconst topPost = posts[0] || {};\nreturn [{ json: { postsText, newMemberCount, topPostTitle: topPost.idea_title, topPostContent: topPost.linkedin_content } }];"
      },
      "id": "nl-prep",
      "name": "NL: Prepare Newsletter Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 560]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 2000,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"You are Saksham, founder of Planora and an AI community for CA firms in India (co-run with Sachit, a CA). Write a weekly newsletter.\\n\\nThis week's content performance:\\n{{ $json.postsText }}\\n\\nNew community members this week: {{ $json.newMemberCount }}\\nTop post: {{ $json.topPostTitle }}\\n\\nWrite in this format:\\n---SUBJECT---\\n[Punchy subject line, under 60 chars, no clickbait]\\n---HTML---\\n[Full HTML email body. Sections: (1) This week in AI for CAs — 2-3 sentences, (2) Top post of the week — excerpt + insight, (3) Tool tip of the week — one practical AI tip for CA firms, (4) Community highlight — celebrate new members, encourage engagement, (5) One thing to do this week — single actionable step. Sign off as Saksham. Footer with unsubscribe placeholder.]\\n---END---\\n\\nTone: direct, warm, no corporate fluff. Like a founder talking to early believers.\"\n  }]\n}",
        "options": {}
      },
      "id": "nl-claude",
      "name": "NL: Claude Draft Newsletter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 560]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content[0].text;\nconst subjectMatch = raw.match(/---SUBJECT---\\n([\\s\\S]*?)\\n---HTML---/);\nconst htmlMatch = raw.match(/---HTML---\\n([\\s\\S]*?)\\n---END---/);\nconst subject = subjectMatch ? subjectMatch[1].trim() : 'Weekly AI for CAs digest';\nconst html = htmlMatch ? htmlMatch[1].trim() : raw;\nreturn [{ json: { subject, html, generated_at: new Date().toISOString() } }];"
      },
      "id": "nl-parse",
      "name": "NL: Parse Subject + HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 560]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/newsletter_queue",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"subject\": \"{{ $json.subject }}\",\n  \"html_body\": {{ JSON.stringify($json.html) }},\n  \"status\": \"pending_review\",\n  \"week_of\": \"{{ $now.toISODate() }}\"\n}",
        "options": {}
      },
      "id": "nl-save",
      "name": "NL: Save Draft to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 560]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
