        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/newsletter_queue?id=eq.{{ $('NL: Publish Webhook').item.json.body.newsletter_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"status\": \"sent\", \"sent_at\": \"{{ $now.toISO() }}\" }",
        "options": {}
