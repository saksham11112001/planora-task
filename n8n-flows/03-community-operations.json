{
  "name": "03 · AI Community Operations",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 2 * * 1-5" }]
        }
      },
      "id": "wa-trigger",
      "name": "WA: Daily Trigger (Mon-Fri 7:30 IST)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 100]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/content_queue?status=eq.published&whatsapp_sent=is.null&order=scheduled_at.asc&limit=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {}
      },
      "id": "wa-fetch-post",
      "name": "WA: Fetch Today's Approved Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 100]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{
            "leftValue": "={{ $json.length }}",
            "rightValue": 0,
            "operator": { "type": "number", "operation": "gt" }
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wa-has-content",
      "name": "WA: Has Content?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [480, 100]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 400,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"You are Saksham, founder of Planora — a CA-focused task management SaaS and AI community for CA firms in India.\\n\\nConvert this LinkedIn post into a WhatsApp community drop. Rules:\\n- Under 180 words\\n- Conversational, no jargon\\n- Start with a hook (question or bold statement)\\n- 1 key insight or tip\\n- End with a question to spark replies\\n- No bullet points — flowing text\\n- Max 2 emojis\\n\\nLinkedIn post:\\n{{ $('WA: Fetch Today\\'s Approved Post').item.json[0].linkedin_content }}\\n\\nTopic: {{ $('WA: Fetch Today\\'s Approved Post').item.json[0].idea_title }}\\n\\nReturn ONLY the WhatsApp message text, nothing else.\"\n  }]\n}",
        "options": {}
      },
      "id": "wa-claude-repurpose",
      "name": "WA: Claude Repurpose for WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 60]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content[0].text;\nconst postId = $('WA: Fetch Today\\'s Approved Post').item.json[0].id;\nreturn [{ json: { whatsapp_message: raw, post_id: postId } }];"
      },
      "id": "wa-parse",
      "name": "WA: Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 60]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.WHATSAPP_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $env.WHATSAPP_COMMUNITY_GROUP_ID }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": \"{{ $json.whatsapp_message }}\" }\n}",
        "options": {}
      },
      "id": "wa-post",
      "name": "WA: Post to Community Group",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 60]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/content_queue?id=eq.{{ $('WA: Parse Message').item.json.post_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"whatsapp_sent\": true,\n  \"whatsapp_content\": \"{{ $('WA: Parse Message').item.json.whatsapp_message }}\"\n}",
        "options": {}
      },
      "id": "wa-mark-sent",
      "name": "WA: Mark Sent in Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 60]
