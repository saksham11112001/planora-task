    {
      "parameters": {
        "jsCode": "const newOrgs = $('MRR: Fetch New Orgs This Week').all().map(i => i.json);\nconst newMembers = $('MRR: Fetch New Community Members').all().map(i => i.json);\nconst nlSubs = $('MRR: Fetch Newsletter Sub Count').all().length;\n\nconst paidOrgs = newOrgs.filter(o => o.plan_tier !== 'free');\nconst newOrgsList = newOrgs.length > 0\n  ? newOrgs.map(o => `• ${o.name} (${o.plan_tier})`).join('\\n')\n  : 'None this week';\n\nconst weekDate = new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n\nreturn [{ json: {\n  newOrgCount: newOrgs.length,\n  paidOrgCount: paidOrgs.length,\n  newOrgsList,\n  newCommunityMemberCount: newMembers.length,\n  newsletterSubCount: nlSubs,\n  weekOf: weekDate\n}}];"
      },
