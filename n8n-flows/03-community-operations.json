        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Planora <{{ $env.FROM_EMAIL }}>\",\n  \"to\": [\"saksham.gpt2001@gmail.com\"],\n  \"subject\": \"[REVIEW] Newsletter draft: {{ $('NL: Parse Subject + HTML').item.json.subject }}\",\n  \"html\": \"<p><strong>Newsletter draft ready for review.</strong></p><p>Newsletter ID: {{ $('NL: Save Draft to Supabase').item.json[0].id }}</p><p>To publish, POST to your n8n webhook: <code>/webhook/newsletter-publish</code> with body <code>{newsletter_id: \\\"ID\\\"}</code></p><hr/>{{ $('NL: Parse Subject + HTML').item.json.html }}\"\n}",
        "options": {}
      },
      "id": "nl-preview-email",
