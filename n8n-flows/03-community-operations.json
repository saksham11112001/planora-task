        "jsonBody": "={{ $input.all().map(item => ({ from: `Saksham from Planora <${$env.FROM_EMAIL}>`, to: [item.json.email], subject: $('NL: Fetch Approved Draft').item.json[0].subject, html: $('NL: Fetch Approved Draft').item.json[0].html_body })) }}",
