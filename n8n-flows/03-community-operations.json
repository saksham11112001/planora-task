          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"Saksham from Planora <{{ $env.FROM_EMAIL }}>\",\n  \"to\": [\"{{ $('Member: Join Webhook').item.json.body.email }}\"],\n  \"subject\": \"Welcome to the AI for CAs community\",\n  \"html\": \"<p>Hey {{ $('Member: Join Webhook').item.json.body.name }},</p><p>You're in. Welcome to the community.</p><p>Here's what happens next:</p><ul><li><strong>WhatsApp drop</strong> — every weekday morning, one practical AI tip for CA firms. Short, actionable, no fluff.</li><li><strong>Weekly newsletter</strong> — Sunday evenings, what worked this week plus a tool tip you can use Monday morning.</li><li><strong>Prompt library</strong> (Pro members) — 200+ CA-specific prompts, searchable and copy-paste ready.</li></ul><p>One thing to do right now: reply to this email and tell me the #1 thing eating your time as a CA firm. I read every reply.</p><p>— Saksham</p><p style='font-size:12px;color:#94a3b8;'>Planora · sng-adwisers.com</p>\"\n}",
        "options": {}
      },
