    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 1500,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"You are Saksham, founder of Planora. You just launched a new AI tool for CA firms.\\n\\nTool details:\\nName: {{ $json.body.tool_name }}\\nTagline: {{ $json.body.tagline }}\\nDescription: {{ $json.body.description }}\\nPrice: Rs. {{ $json.body.price_inr }}\\nURL: {{ $json.body.url }}\\nCategory: {{ $json.body.category }}\\n\\nGenerate launch content in this EXACT format:\\n---LINKEDIN---\\n[Hook line. Story of why you built it. What problem it solves. 3 bullets on what it does. CTA to URL. 900-1100 chars. Founder voice — real, not corporate.]\\n---INSTAGRAM---\\n[Punchy caption, max 220 chars. 1 emoji. 15 relevant hashtags on new line.]\\n---WHATSAPP---\\n[Community announcement under 150 words. Conversational. Why it matters to CAs. Price or free mention. One question to spark replies.]\\n---END---\"\n  }]\n}",
        "options": {}
      },
      "id": "launch-claude",
      "name": "Launch: Claude Generate Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 1500]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.content[0].text;\nconst liMatch = raw.match(/---LINKEDIN---\\n([\\s\\S]*?)\\n---INSTAGRAM---/);\nconst igMatch = raw.match(/---INSTAGRAM---\\n([\\s\\S]*?)\\n---WHATSAPP---/);\nconst waMatch = raw.match(/---WHATSAPP---\\n([\\s\\S]*?)\\n---END---/);\nconst tool = $('Launch: Tool Launch Webhook').item.json.body;\nreturn [{ json: {\n  linkedin: liMatch ? liMatch[1].trim() : '',\n  instagram: igMatch ? igMatch[1].trim() : '',\n  whatsapp: waMatch ? waMatch[1].trim() : '',\n  tool_name: tool.tool_name,\n  tool_url: tool.url,\n  price_inr: tool.price_inr\n}}];"
      },
